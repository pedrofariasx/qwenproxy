# =============================================================================
# QwenProxy - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Port the proxy HTTP server binds to.
# Default: 3000
PORT=3000

# Host interface the server binds to.
# Use "0.0.0.0" to accept connections from any interface.
# Default: 0.0.0.0
HOST=0.0.0.0

# Application environment.
# Default: development
NODE_ENV=development

# API key required by clients in the Authorization header (Bearer token).
# Leave empty to disable proxy auth.
# Default: (none)
API_KEY=

# Enable HTTPS for the proxy server.
# Default: false
SSL_ENABLED=false

# Path to the SSL certificate file (PEM format).
# Default: (none)
SSL_CERT_PATH=

# Path to the SSL private key file (PEM format).
# Default: (none)
SSL_KEY_PATH=

# ---------------------------------------------------------------------------
# Browser
# ---------------------------------------------------------------------------

# Run the browser in headless mode.
# Default: true
BROWSER_HEADLESS=true

# Browser engine used for Playwright startup and prewarm.
# Values: chromium | firefox | webkit | chrome | edge
# Default: chromium
BROWSER=chromium

# Custom path to the browser executable binary.
# Useful for non-standard installations or native system browsers
# (e.g., C:\Program Files\Google\Chrome\Application\chrome.exe on Windows).
# Leave empty to let Playwright use its bundled browser.
# Default: (none)
BROWSER_EXECUTABLE_PATH=

# Directory where browser profiles (sessions, cookies) are persisted.
# Default: ./qwen_profile
QWEN_PROFILES_PATH=./qwen_profile

# Custom User-Agent string for the browser.
# Default: Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 ...
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# ---------------------------------------------------------------------------
# Timeouts
# ---------------------------------------------------------------------------

# Maximum time (ms) to wait for a full page navigation.
# Default: 30000
NAVIGATION_TIMEOUT=30000

# Maximum time (ms) to wait for a page element / selector.
# Default: 15000
PAGE_TIMEOUT=15000

# Maximum time (ms) for individual HTTP requests made by the browser.
# Default: 10000
HTTP_TIMEOUT=10000

# Maximum time (ms) for a complete Qwen chat response cycle.
# Default: 120000
CHAT_TIMEOUT=120000

# Graceful shutdown timeout (ms). Force-exit if not completed in time.
# Default: 10000
SHUTDOWN_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# Cache
# ---------------------------------------------------------------------------

# Default TTL for cached responses, in seconds.
# Default: 3600
CACHE_TTL=3600

# TTL (seconds) for cached responses specifically.
# Default: 1800
RESPONSE_TTL=1800

# Maximum entries in the in-memory response cache.
# Default: 10000
CACHE_MAX_ENTRIES=10000

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------

# How often (ms) internal metrics are collected and refreshed.
# Default: 10000
METRICS_INTERVAL=10000

# How often (ms) the watchdog checks browser health.
# Default: 5000
WATCHDOG_INTERVAL=5000

# Number of consecutive watchdog failures before a recovery action is taken.
# Default: 3
WATCHDOG_FAILURES=3

# RSS memory warning threshold in MB (Resident Set Size).
# When the process exceeds this, the watchdog enters "warning" state.
# Default: 512
RAM_WARNING=512

# RSS memory critical threshold in MB (Resident Set Size).
# When the process exceeds this, the watchdog triggers recovery.
# Default: 1024
RAM_CRITICAL=1024

# WebSocket messages warning threshold (count).
# Default: 50
WS_WARNING=50

# WebSocket messages critical threshold (count).
# Default: 100
WS_CRITICAL=100

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------

# Enable or disable per-IP rate limiting on API endpoints.
# Default: false
RATE_LIMIT_ENABLED=false

# Maximum number of requests allowed within the rate-limit window.
# Default: 60
RATE_LIMIT_MAX=60

# Rate-limit window duration in milliseconds.
# Default: 60000 (1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Name of the request header used to derive the rate-limit key.
# Default: x-forwarded-for
RATE_LIMIT_HEADER=x-forwarded-for

# ---------------------------------------------------------------------------
# Executor (Agentic Loop)
# ---------------------------------------------------------------------------

# Enable the agentic executor (multi-turn tool-calling loop).
# Default: false
EXECUTOR_ENABLED=false

# Maximum number of tool-calling turns per request.
# Default: 10
EXECUTOR_MAX_TURNS=10

# Total timeout (ms) for the full executor loop.
# Default: 120000
EXECUTOR_TIMEOUT_MS=120000

# ---------------------------------------------------------------------------
# Tool Calling
# ---------------------------------------------------------------------------

# Timeout (ms) for a single tool execution.
# Default: 30000
TOOL_TIMEOUT_MS=30000

# Maximum serialised size (bytes) of tool arguments.
# Default: 1048576
TOOL_MAX_ARGUMENTS_BYTES=1048576

# Maximum serialised size (bytes) of a tool result.
# Default: 524288
TOOL_MAX_RESULT_BYTES=524288

# Maximum number of tool calls a single model response can emit.
# Excess tool calls are silently dropped to prevent runaway loops.
# Default: 20
TOOL_MAX_CALLS=20

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log output format.
# Values: text | json
# Default: text
LOG_FORMAT=text

# Relay browser console (page.evaluate) messages to stdout.
# Default: false
LOG_CONSOLE=false

# ---------------------------------------------------------------------------
# Qwen API
# ---------------------------------------------------------------------------

# Base URL for the Qwen web chat interface.
# Default: https://chat.qwen.ai
QWEN_BASE_URL=https://chat.qwen.ai

# Direct HTTP endpoint for the Qwen API.
# Default: https://api.qwen.ai/v1/chat
QWEN_HTTP_ENDPOINT=https://api.qwen.ai/v1/chat

# Qwen account email address used for automated login.
# Default: (none)
QWEN_EMAIL=

# Qwen account password.
# Default: (none)
QWEN_PASSWORD=

# Encryption key used to obfuscate Qwen credentials at rest.
# Generate one with: openssl rand -hex 32
# Default: (none)
QWEN_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Legacy / ignored by runtime
# ---------------------------------------------------------------------------

# Legacy browser toggle kept for old installs. Prefer BROWSER_HEADLESS.
# HEADLESS=true

# Legacy browser profile path kept for old installs. Prefer QWEN_PROFILES_PATH.
# USER_DATA_DIR=./qwen_profile

# Legacy cache TTL alias. Prefer CACHE_TTL.
# CACHE_TTL_MS=3600

# Legacy watchdog interval alias. Prefer WATCHDOG_INTERVAL.
# WATCHDOG_INTERVAL_MS=5000

# Legacy log level variable. The runtime now derives logging from code defaults.
# LOG_LEVEL=info

# Legacy timeout variable. The runtime no longer reads this name.
# REQUEST_TIMEOUT_MS=120000

# Legacy metrics prefix variable. The runtime no longer reads this name.
# METRICS_PREFIX=qwenproxy

# Legacy metrics port variable. The runtime no longer reads this name.
# METRICS_PORT=0

# Legacy watchdog memory limit variable. The runtime no longer reads this name.
# WATCHDOG_MEMORY_LIMIT_MB=-1

# Legacy direct Qwen API key variable. The runtime no longer reads this name.
# QWEN_API_KEY=

# ---------------------------------------------------------------------------
# Testing (Optional — used only in test suites)
# ---------------------------------------------------------------------------

# Set to "true" to bypass Playwright in tests (uses mock responses).
# Default: (none)
TEST_MOCK_PLAYWRIGHT=true

# Mock session ID used when TEST_MOCK_PLAYWRIGHT is active.
# Default: mock-session
TEST_SESSION_ID=mock-session

# =============================================================================
# Quick Reference — Example .env for a typical deployment
# =============================================================================
#
#   PORT=3000
#   HOST=0.0.0.0
#   API_KEY=sk-my-secret-key
#   NODE_ENV=production
#
#   QWEN_EMAIL=user@example.com
#   QWEN_PASSWORD=s3cret
#   QWEN_PROFILES_PATH=./qwen_profile
#   BROWSER_HEADLESS=true
#   BROWSER=chromium
#
#   LOG_FORMAT=text
#   LOG_CONSOLE=false
#
#   CACHE_TTL=3600
#   CACHE_MAX_ENTRIES=10000
#   WATCHDOG_INTERVAL=5000
#   RATE_LIMIT_ENABLED=false
#   EXECUTOR_ENABLED=false
#
# =============================================================================
