# Server
PORT=3000
HOST=0.0.0.0

# Proxy API key. Leave empty to allow unauthenticated requests.
API_KEY=

# Qwen credentials for automatic login/account rotation.
QWEN_EMAIL=
QWEN_PASSWORD=

# Set to 'true' to bypass account rotation and use only guest mode.
QWEN_GUEST_MODE_ONLY=false

# Qwen endpoints.
QWEN_BASE_URL=https://chat.qwen.ai
QWEN_HTTP_ENDPOINT=https://api.qwen.ai/v1/chat

# Optional Qwen API key when using the HTTP endpoint.
QWEN_API_KEY=

# Browser configuration.
BROWSER=chromium
HEADLESS=true
USER_DATA_DIR=./qwen_profiles
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
LOG_CONSOLE=false

# Anti-bot risk reduction. Defaults tuned for LOW LATENCY streaming.
# NOTE: warm pool + more lanes generate some proactive traffic. Lower these
# values if you need to minimize automated requests to Qwen.
HEADERS_TTL_MS=1800000
BACKGROUND_HEADER_REFRESH=true
# Warm pool eliminates per-request chat creation (~800-2000ms off TTFT).
WARM_POOL_SIZE=3
WARM_POOL_LOW_WATER=2
WARM_POOL_TTL_MS=600000
WARM_POOL_STARTUP=true
SESSION_KEEPER_ENABLED=false
ACCOUNT_INIT_CONCURRENCY=4
ACCOUNT_INIT_STAGGER_MIN_MS=300
ACCOUNT_INIT_STAGGER_MAX_MS=900
PRECAPTURE_HEADERS_STARTUP=false
PRECAPTURE_HEADERS_CONCURRENCY=1
PRECAPTURE_HEADERS_STAGGER_MIN_MS=2500
PRECAPTURE_HEADERS_STAGGER_MAX_MS=5000

# Use one configured account split into isolated browser contexts for concurrency.
# Increase ACCOUNT_LANES to run parallel streams (recommended: number of accounts,
# or 2-4 when using SINGLE_ACCOUNT_MODE). lanes > 1 disables per-account stream
# serialization, allowing concurrent requests without queueing.
SINGLE_ACCOUNT_MODE=false
SINGLE_ACCOUNT_ID=
SINGLE_ACCOUNT_EMAIL=
ACCOUNT_LANES=2

# Timeouts (milliseconds). Lower chat/idle timeouts fail fast on stalled upstream.
NAVIGATION_TIMEOUT=45000
PAGE_TIMEOUT=30000
HTTP_TIMEOUT=30000
HEADERS_TIMEOUT=60000
CHAT_TIMEOUT=60000
STREAM_IDLE_TIMEOUT=60000

# Cache TTL values (seconds).
CACHE_TTL=3600
RESPONSE_TTL=1800

# Metrics collection interval (milliseconds).
METRICS_INTERVAL=10000

# Watchdog settings.
WATCHDOG_INTERVAL=5000
WATCHDOG_FAILURES=3
RAM_WARNING=80
RAM_CRITICAL=95
WS_WARNING=50
WS_CRITICAL=100
