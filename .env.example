PORT=3000
API_KEY=your_proxy_api_key
HOST=0.0.0.0

# Single account (legacy)
QWEN_EMAIL=your_email@example.com
QWEN_PASSWORD=your_password

# Multiple accounts (indexed)
# QWEN_EMAIL_1=first@example.com
# QWEN_PASSWORD_1=password1
# QWEN_EMAIL_2=second@example.com
# QWEN_PASSWORD_2=password2

# SQLite account storage
QWENPROXY_DATA_DIR=./data
# QWENPROXY_DB_PATH=./data/qwenproxy.db

# Browser profiles
USER_DATA_DIR=./qwen_profiles/global
QWENPROXY_PROFILES_DIR=./qwen_profiles

# Terminal debug: off | basic | full | raw
QWENPROXY_DEBUG=off
QWENPROXY_DEBUG_MAX_CHARS=1200
QWENPROXY_DEBUG_SHOW_PROMPT=false
