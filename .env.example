# =============================================================================
# QwenProxy - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Port the proxy HTTP server binds to.
# Default: 3000
PORT=3000

# Host interface the server binds to.
# Use "0.0.0.0" to accept connections from any interface.
# Default: 0.0.0.0
HOST=0.0.0.0

# API key required by clients in the Authorization header (Bearer token).
# Leave empty to disable authentication.
# Default: (none)
API_KEY=

# Application environment. Affects error verbosity and behaviour.
# Values: development | production | test
# Default: development
NODE_ENV=development

# ---------------------------------------------------------------------------
# Browser
# ---------------------------------------------------------------------------

# Qwen account email address used for automated login.
# Leave empty to skip auto-login (manual browser login required).
# Default: (none)
QWEN_EMAIL=your_email@example.com

# Qwen account password.
# Leave empty to skip auto-login.
# Default: (none)
QWEN_PASSWORD=your_password

# Directory where browser profiles (sessions, cookies) are persisted.
# Default: ./qwen_profile
QWEN_PROFILES_PATH=./qwen_profile

# Run the browser in headless mode (no visible window).
# Set to false for debugging or manual login flows.
# Default: true
BROWSER_HEADLESS=true

# Browser engine to use when launching the login helper (login.ts).
# Values: chromium | firefox | webkit | chrome | edge
# Default: chromium
BROWSER=chromium

# Custom User-Agent string for the browser.
# Default: Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 ...
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# ---------------------------------------------------------------------------
# Timeouts and Limits
# ---------------------------------------------------------------------------

# Maximum time (ms) to wait for a full page navigation.
# Default: 30000
NAVIGATION_TIMEOUT=30000

# Maximum time (ms) to wait for a page element / selector.
# Default: 15000
PAGE_TIMEOUT=15000

# Maximum time (ms) for individual HTTP requests made by the browser.
# Default: 10000
HTTP_TIMEOUT=10000

# Maximum time (ms) for a complete Qwen chat response cycle.
# Default: 120000
CHAT_TIMEOUT=120000

# General timeout (ms) for proxied API requests.
# Default: 120000
REQUEST_TIMEOUT_MS=120000

# Enable TCP keepalive on the HTTP server sockets.
# Default: true
KEEPALIVE=true

# Maximum number of retries for transient failures (network, login).
# Default: 3
MAX_RETRIES=3

# Graceful shutdown timeout (ms). Force-exit if not completed in time.
# Default: 10000
SHUTDOWN_TIMEOUT_MS=10000

# Maximum request body size in bytes (e.g. chat completion payload).
# Default: 1048576 (1 MB)
MAX_REQUEST_BODY_BYTES=1048576

# Maximum number of messages allowed in a single chat completion request.
# Default: 100
MAX_MESSAGES=100

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log verbosity level.
# Values: debug | info | warn | error
# Default: info
LOG_LEVEL=info

# Log output format.
# Values: text | json
# Default: text
LOG_FORMAT=text

# Relay browser console (page.evaluate) messages to stdout.
# Set to true when debugging browser interactions.
# Default: false
LOG_CONSOLE=false

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------

# Enable or disable per-IP rate limiting on API endpoints.
# Default: false
RATE_LIMIT_ENABLED=false

# Maximum number of requests allowed within the rate-limit window.
# Default: 100
RATE_LIMIT_MAX=100

# Rate-limit window duration in milliseconds.
# Default: 60000 (1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Name of the response header that carries rate-limit information.
# Default: X-RateLimit
RATE_LIMIT_HEADER=X-RateLimit

# ---------------------------------------------------------------------------
# Watchdog (Browser Health Monitoring)
# ---------------------------------------------------------------------------

# How often (ms) the watchdog checks browser health.
# Default: 5000
WATCHDOG_INTERVAL_MS=5000

# Memory limit (MB) for the browser process. If exceeded the watchdog acts.
# Use -1 to disable memory checks.
# Default: -1
WATCHDOG_MEMORY_LIMIT_MB=-1

# Number of unacknowledged WebSocket messages that trigger a congestion alert.
# Default: 100
WATCHDOG_WS_CONGESTION_LIMIT=100

# Number of consecutive watchdog failures before a recovery action is taken.
# Default: 3
WATCHDOG_FAILURES=3

# RAM usage warning threshold (percent).
# Default: 80
RAM_WARNING=80

# RAM usage critical threshold (percent).
# Default: 95
RAM_CRITICAL=95

# WebSocket messages warning threshold (count).
# Default: 50
WS_WARNING=50

# WebSocket messages critical threshold (count).
# Default: 100
WS_CRITICAL=100

# ---------------------------------------------------------------------------
# Cache
# ---------------------------------------------------------------------------

# Default TTL for cached responses.
# The config schema in config.ts parses this as seconds (default 3600 = 1 hour).
# Default: 3600
CACHE_TTL_MS=3600

# TTL (seconds) for cached responses specifically.
# Default: 1800 (30 minutes)
RESPONSE_TTL=1800

# Maximum entries in the in-memory response cache.
# Default: 1000
CACHE_MAX_ENTRIES=1000

# ---------------------------------------------------------------------------
# Metrics (Prometheus)
# ---------------------------------------------------------------------------

# Prefix applied to all Prometheus metric names.
# Default: qwenproxy
METRICS_PREFIX=qwenproxy

# Port for the Prometheus metrics HTTP endpoint (separate from the main API).
# Set to 0 to disable the standalone metrics server.
# Default: 0
METRICS_PORT=0

# How often (ms) internal metrics are collected and refreshed.
# Default: 10000
METRICS_INTERVAL=10000

# ---------------------------------------------------------------------------
# Executor (Agentic Loop)
# ---------------------------------------------------------------------------

# Enable the agentic executor (multi-turn tool-calling loop).
# Default: false
EXECUTOR_ENABLED=false

# Maximum number of tool-calling turns per request.
# Default: 10
EXECUTOR_MAX_TURNS=10

# Total timeout (ms) for the full executor loop.
# Default: 300000 (5 minutes)
EXECUTOR_TIMEOUT_MS=300000

# ---------------------------------------------------------------------------
# Tool Calling
# ---------------------------------------------------------------------------

# Timeout (ms) for a single tool execution.
# Default: 30000
TOOL_TIMEOUT_MS=30000

# Maximum serialised size (bytes) of tool arguments.
# Default: 51200 (50 KB)
TOOL_MAX_ARGUMENTS_BYTES=51200

# Maximum serialised size (bytes) of a tool result.
# Default: 51200 (50 KB)
TOOL_MAX_RESULT_BYTES=51200

# ---------------------------------------------------------------------------
# Security / SSL
# ---------------------------------------------------------------------------

# Enable HTTPS for the proxy server.
# Default: false
SSL_ENABLED=false

# Path to the SSL certificate file (PEM format). Required when SSL_ENABLED=true.
# Default: (none)
SSL_CERT_PATH=./certs/cert.pem

# Path to the SSL private key file (PEM format). Required when SSL_ENABLED=true.
# Default: (none)
SSL_KEY_PATH=./certs/key.pem

# Encryption key used to obfuscate Qwen credentials at rest.
# Generate one with: openssl rand -hex 32
# Default: (none)
QWEN_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Qwen API (Advanced)
# ---------------------------------------------------------------------------

# Base URL for the Qwen web chat interface.
# Default: https://chat.qwen.ai
QWEN_BASE_URL=https://chat.qwen.ai

# Direct HTTP endpoint for the Qwen API (bypasses browser for some flows).
# Default: https://api.qwen.ai/v1/chat
QWEN_HTTP_ENDPOINT=https://api.qwen.ai/v1/chat

# API key for direct Qwen API access (if available).
# Leave empty to use browser-based chat only.
# Default: (none)
QWEN_API_KEY=

# ---------------------------------------------------------------------------
# Testing (Optional — used only in test suites)
# ---------------------------------------------------------------------------

# Set to "true" to bypass Playwright in tests (uses mock responses).
# Default: (none)
# TEST_MOCK_PLAYWRIGHT=true

# Mock session ID used when TEST_MOCK_PLAYWRIGHT is active.
# Default: mock-session
# TEST_SESSION_ID=mock-session

# =============================================================================
# Quick Reference — Example .env for a typical deployment
# =============================================================================
#
#   PORT=3000
#   HOST=0.0.0.0
#   API_KEY=sk-my-secret-key
#   NODE_ENV=production
#
#   QWEN_EMAIL=user@example.com
#   QWEN_PASSWORD=s3cret
#   BROWSER_HEADLESS=true
#
#   LOG_LEVEL=info
#
#   CACHE_TTL_MS=3600
#   CACHE_MAX_ENTRIES=1000
#
#   WATCHDOG_INTERVAL_MS=5000
#   WATCHDOG_MEMORY_LIMIT_MB=1024
#   WATCHDOG_WS_CONGESTION_LIMIT=100
#
# =============================================================================
